-- 1. 대시보드 상단 요약 수치 (배송 지연율, 셀러 지연율, 6일 이상 지연율)
  
WITH order_item_summary AS (
  SELECT 
    o.order_id,
    o.is_delayed,
    MAX(CASE WHEN o.order_delivered_carrier_date::DATE > i.shipping_limit_date::DATE THEN 1 END) AS is_seller_delayed,
    MAX(CASE WHEN o.delivery_efficiency <= -6 THEN 1 END) AS is_long_delayed
  FROM orders o
  JOIN items i ON o.order_id = i.order_id
  WHERE o.order_status = 'delivered'
  GROUP BY o.order_id, o.is_delayed
)
SELECT  
  SUM(is_delayed) *1.0 / NULLIF(COUNT(order_id),0) AS delay_rate,
  SUM(is_seller_delayed) *1.0 / NULLIF(COUNT(order_id),0) AS seller_delay_rate,
  SUM(is_long_delayed) *1.0 / NULLIF(SUM(is_delayed),0) AS long_delay_rate
FROM order_item_summary;

--------------------------------------------
  
-- 2. 월별 지연 추이, 증감률
  
WITH order_item_summary AS (
  SELECT 
    DATE_TRUNC('month', o.order_purchase_timestamp) AS month,
    o.order_id,
    o.is_delayed,
    MAX(CASE WHEN o.order_delivered_carrier_date::DATE > i.shipping_limit_date::DATE THEN 1 ELSE 0 END) AS is_seller_delayed,
    MAX(CASE WHEN i.delivery_efficiency <= -6 THEN 1 ELSE 0 END) AS is_long_delayed
    FROM orders o
    JOIN items i ON o.order_id = i.order_id
    WHERE o.order_status = 'delivered'
    GROUP BY 1, 2, 3
), monthly_kpi AS (
  SELECT 
		month,
    SUM(is_delayed) *1.0 / NULLIF(COUNT(order_id),0) AS delay_rate,
    SUM(is_seller_delayed) *1.0 / NULLIF(COUNT(order_id),0) AS seller_delay_rate,
    SUM(is_long_delayed) *1.0 / NULLIF(SUM(is_delayed),0) AS long_delay_rate
    FROM order_item_summary 
    GROUP BY 1
), prev_kpi AS (
	SELECT *,
    LAG(delay_rate) OVER (ORDER BY month) AS prev_delay_rate,
    LAG(seller_delay_rate) OVER (ORDER BY month) AS prev_seller_rate,
    LAG(long_delay_rate) OVER (ORDER BY month) AS prev_long_delay_rate
	FROM monthly_kpi
)
SELECT 
    month,
    round(delay_rate::numeric, 4) AS delay_rate,
    round(((delay_rate - prev_delay_rate) 
        / NULLIF(prev_delay_rate, 0))::numeric, 4) AS delay_rate_mom,
    
    round(seller_delay_rate::numeric, 4) AS seller_delay_rate,
    round(((seller_delay_rate - prev_seller_rate)
        / NULLIF(prev_seller_rate, 0))::numeric, 4) AS seller_delay_rate_mom,
    
    round(long_delay_rate::numeric, 4) AS long_delay_rate,
    round(((long_delay_rate - prev_long_delay_rate) 
        / NULLIF(prev_long_delay_rate, 0))::numeric, 4) AS long_delay_rate_mom   
FROM prev_kpi
ORDER BY 1;

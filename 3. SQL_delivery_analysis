-- 4. 지연율이 높은 노선 

SELECT
	seller_state,
	customer_state,
	CASE WHEN seller_state = customer_state THEN '같은 주' ELSE '다른 주' END AS route_type,
	AVG(order_delivered_customer_date - order_purchase_timestamp) AS avg_delivery_days,
	COUNT(DISTINCT o.order_id) AS order_count,
	SUM(CASE WHEN is_delayed = 1 THEN 1 ELSE 0 END) AS delay_count
FROM orders o
INNER JOIN customers c ON o.customer_id = c.customer_id
INNER JOIN items i ON o.order_id = i.order_id
INNER JOIN sellers s ON i.seller_id = s.seller_id
WHERE o.order_status = 'delivered'
GROUP BY seller_state, customer_state, route_type
ORDER BY delay_count DESC;		


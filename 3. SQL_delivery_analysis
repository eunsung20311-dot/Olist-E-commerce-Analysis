-- 3. 지연 일수 분포
  
SELECT 
	CASE
		WHEN ABS(delivery_efficiency) BETWEEN 1 AND 3 THEN '1-3'
		WHEN ABS(delivery_efficiency) BETWEEN 4 AND 6 THEN '4-6'
		WHEN ABS(delivery_efficiency) BETWEEN 7 AND 10 THEN '7-10'
		WHEN ABS(delivery_efficiency) BETWEEN 11 AND 20 THEN '11-20'
		WHEN ABS(delivery_efficiency) >= 21 THEN '21~'
	END AS delay_bins,
	COUNT(*) AS counts
FROM orders
WHERE is_delayed = 1
GROUP BY 1
ORDER BY MIN(ABS(delivery_efficiency));

